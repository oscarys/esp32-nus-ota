# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
dist/
.pytest_cache/
.coverage
htmlcov/

# ── MicroPython build artifacts ───────────────────────────────────────────────
*.mpy

# ── Flutter — generated / local ───────────────────────────────────────────────
flutter-client/.dart_tool/
flutter-client/.flutter-plugins
flutter-client/.flutter-plugins-dependencies
flutter-client/.flutter-plugins-dependencies
flutter-client/.packages
flutter-client/build/

# pubspec.lock is intentionally NOT ignored for apps (only for packages).
# Committing it pins exact dependency versions for reproducible builds.
# flutter-client/pubspec.lock   ← keep this committed

# ── Android — generated / local ───────────────────────────────────────────────
flutter-client/android/.gradle/
flutter-client/android/local.properties   # machine-specific SDK path
flutter-client/android/key.properties     # signing secrets — never commit
flutter-client/android/app/google-services.json  # Firebase config if added later
*.keystore
*.jks

# Gradle wrapper — keep the jar and properties, ignore the cache
flutter-client/android/.gradle/
flutter-client/android/captures/

# Generated plugin registrant (produced at build time, not hand-edited)
flutter-client/android/app/src/main/java/io/flutter/plugins/GeneratedPluginRegistrant.java

# Android Studio / IntelliJ module files (generated by IDE)
flutter-client/android/*.iml
flutter-client/android/app/*.iml

# ── IDEs ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── OTA runtime artifacts (should never land in the repo) ────────────────────
_ota_tmp
*.bak
_boot_count
